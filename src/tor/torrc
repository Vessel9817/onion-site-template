# Exposing hidden service to tor network
HiddenServiceDir /var/lib/tor/website/

# Redirecting requests to nginx
HiddenServicePort 80 10.5.0.2:80
#HiddenServicePort 443 10.5.0.2:443

# Configuring Vanguards
ControlPort 9051
CookieAuthentication 1
DataDirectory /var/lib/tor/data/

# Configuring OnionScan
SocksPort 10.5.3.2:9050

# Making sure we don't leak DNS queries
TestSocks 1

# Disabling all connections that leak DNS queries
SafeSocks 1
