{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            // General JS
            "ESNext",

            // Web interfaces
            "dom",
            "dom.iterable",

            // Asynchronicity and promises
            "ES2020.Promise",
            "ESNext.asynciterable"
        ],
        "allowJs": true,
        "checkJs": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,
        "module": "ES2022",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "noEmit": false,
        "importHelpers": true,
        "newLine": "lf",
        "stripInternal": true,
        "outDir": "dist"
    },
    "include": ["**/*"],
    "exclude": [
        "**/coverage/",
        "**/licenses/",
        "**/logs/",
        "**/node_modules/",
        "**/secrets/",
        "**/temp/",
        "**/tmp/",
        "**/dist/",
        "webpack"
    ]
}
