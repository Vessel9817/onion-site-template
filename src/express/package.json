    },
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "start": "node --env-file=./secrets/.env ./dist/index.cjs",
        "build": "node --run=build:prod",
        "build:prod": "cross-env NODE_ENV=\"production\" NODE_OPTIONS=\"--no-experimental-strip-types --import tsx\" webpack -c ./webpack/webpack.config.ts",
        "build:dev": "cross-env NODE_ENV=\"development\" NODE_OPTIONS=\"--no-experimental-strip-types --import tsx\" webpack -c ./webpack/webpack.config.ts",
        "tsc": "tsc --noEmit"
    },
    "dependencies": {
        "cors": "^2.8.6",
        "ejs": "^5.0.2",
        "express": "^5.2.1",
        "express-validator": "^7.3.2",
        "mongodb": "^7.2.0",
        "mongoose": "^9.6.1"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.6.2",
        "clean-webpack-plugin": "^4.0.0",
        "cross-env": "^10.1.0",
        "terser-webpack-plugin": "^5.5.0",
        "ts-loader": "^9.5.7",
        "tslib": "^2.8.1",
        "tsx": "^4.21.0",
