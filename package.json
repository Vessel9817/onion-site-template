{
    "name": "website_",
    "version": "0.0.0",
    "private": true,
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Vessel9817/onion-site-template.git"
    },
    "homepage": "https://github.com/Vessel9817/onion-site-template#readme",
    "readme": "https://github.com/Vessel9817/onion-site-template/blob/main/README.md",
    "bugs": {
        "url": "https://github.com/Vessel9817/onion-site-template/issues"
    },
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "start": "node --run=start:prod",
        "build": "docker compose --profile production --profile development --profile license-report --profile onionscan build",
        "pull": "docker compose --profile production --profile development --profile license-report --profile onionscan pull",
        "start:prod": "docker compose --profile production up -d tor",
        "start:dev": "docker compose --profile development up -d",
        "stop": "docker compose --profile production --profile development down --remove-orphans",
        "onionscan": "docker compose up -d onionscan",
        "tsc": "tsc --noEmit",
        "eslint": "eslint . -c ./src/eslint/eslint.config.ts",
        "eslint:fix": "node --run=eslint -- --fix",
        "license-report": "docker compose run --rm license-report"
    },
    "workspaces": {
        "packages": [
            "./src/express",
            "./src/license-report",
            "./src/mongo"
        ]
    },
    "devDependencies": {
        "@eslint/js": "^9.39.3",
        "@eslint/json": "^1.2.0",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^25.5.2",
        "eslint": "^9.39.3",
        "eslint-plugin-import": "^2.32.0",
        "globals": "^17.4.0",
        "jiti": "^2.6.1",
        "tslib": "^2.8.1",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.1"
    }
}
