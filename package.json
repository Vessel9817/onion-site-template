{
    "name": "website_",
    "version": "0.0.0",
    "private": true,
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Vessel9817/onion-site-template.git"
    },
    "homepage": "https://github.com/Vessel9817/onion-site-template#readme",
    "readme": "https://github.com/Vessel9817/onion-site-template/blob/main/README.md",
    "bugs": {
        "url": "https://github.com/Vessel9817/onion-site-template/issues"
    },
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "start": "node --run=start:prod",
        "build": "docker compose --profile production --profile development --profile license-report --profile onionscan build",
        "start:prod": "docker compose --profile production up -d grafana",
        "start:dev": "docker compose --profile development up -d",
        "stop": "docker compose --profile production --profile development down --remove-orphans",
        "onionscan": "docker compose up -d onionscan-ui",
        "tsc": "tsc --noEmit",
        "markdownlint": "markdownlint-cli2",
        "eslint": "eslint . -c ./src/eslint/eslint.config.ts",
        "eslint:fix": "node --run=eslint -- --fix",
        "license-report": "docker compose run --rm license-report"
    },
    "workspaces": {
        "packages": [
            "./src/express",
            "./src/license-report",
            "./src/mongo"
        ]
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@eslint/json": "^2.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^26.1.1",
        "eslint": "^10.6.0",
        "eslint-import-resolver-typescript": "^4.4.5",
        "eslint-plugin-import-x": "^4.17.1",
        "eslint-plugin-sonarjs": "^4.2.0",
        "globals": "^17.7.0",
        "jiti": "^2.7.0",
        "markdownlint-cli2": "^0.23.0",
        "tslib": "^2.8.1",
        "tsx": "^4.23.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.64.0",
        "webpack": "^5.108.4",
        "webpack-cli": "^7.2.1"
    }
}
